#!/bin/bash
# Returns music progress as integer 0-100
pos=$(playerctl metadata --format '{{position}}' 2>/dev/null)
len=$(playerctl metadata --format '{{mpris:length}}' 2>/dev/null)

if [ -z "$pos" ] || [ -z "$len" ] || [ "$len" = "0" ] || [ "$len" = "" ]; then
  echo "0"
  exit 0
fi

awk "BEGIN {
  pct = ($pos / $len) * 100
  if (pct > 100) pct = 100
  if (pct < 0)   pct = 0
  printf \"%.0f\", pct
}"
